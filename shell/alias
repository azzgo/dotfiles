alias lsa='ls -lah'
alias l='ls -lah'
alias ll='ls -alFh'
alias la='ls -lAh'

# Safety first
alias rm="rm -i"

function gcd() {
  local folder
  
  if [[ -n "$1" ]]; then
    # 接收参数时：在 branch 名称（最后一个字段 $NF）上进行模糊匹配
    folder=$(git worktree list | awk -v pattern="$1" '$NF ~ pattern {print $1; exit}')
    if [[ -n $folder ]]; then
      cd "$folder"
    fi
  elif [[ -x $(command -v fzf) ]]; then
    # 不接收参数时：使用 fzf 交互选择
    folder=$(git worktree list | fzf)
    if [[ -n $folder ]]; then
      cd $(echo $folder | awk '{print $1}')
    fi
  fi
}

function gwt() {
  local delete_mode=false
  local skip_confirm=false

  while [[ "$1" == -* ]]; do
    case "$1" in
      -d) delete_mode=true; shift ;;
      -y) skip_confirm=true; shift ;;
      *) break ;;
    esac
  done

  if [[ "$delete_mode" == true ]]; then
    if [[ ! -x $(command -v fzf) ]];then
      echo "fzf is required for deletion"
      return 1
    fi
    selected=$(git worktree list | fzf --reverse)
    if [[ -n $selected ]];then
      path=$(echo $selected | awk '{print $1}')
      branch=$(echo $selected | awk '{print $2}')
      if [[ "$path" == "$PWD"* ]]; then
        cd ~ || return
      fi
      git worktree remove "$path"
      if [[ "$skip_confirm" == true ]]; then
        git branch -D "$branch" 2>/dev/null && echo "Deleted branch $branch"
      else
        read -p "Delete local branch '$branch'? [y/N] " -n 1 -r
        echo
        if [[ "$REPLY" =~ ^[Yy]$ ]]; then
          git branch -D "$branch" && echo "Deleted branch $branch"
        fi
      fi
    fi
  elif [[ -n "$1" ]]; then
    branch_name="$1"
    worktree_path=".worktree/$branch_name"
    mkdir -p .worktree
    if git show-ref --verify --quiet "refs/heads/$branch_name"; then
      git worktree add "$worktree_path" "$branch_name"
    else
      git worktree add "$worktree_path" -b "$branch_name"
    fi
  else
    echo "Usage: gwt <branch_name>   # create worktree at .worktree/<branch_name>"
    echo "       gwt -d              # delete worktree (fuzzy select)"
    echo "       gwt -d -y           # delete worktree and branch without confirm"
  fi
}

function gco() {
  if [[ $# -gt 0 ]];then
    git checkout "$@"
  elif [[ -x  $(command -v fzf) ]];then
    local_branches=$(git branch --format='%(refname:short)')
    remote_branches=$(git branch -r --format='%(refname:lstrip=3)'| grep -v 'HEAD$')
    branches=$(echo -e "${local_branches}\n${remote_branches}" | sort | uniq | awk '{ print length, $0 }' | sort -n | cut -d' ' -f2-)
    if [[ -n $branches ]];then
      git checkout $(echo $branches | fzf --reverse)
    fi
  fi
}

function gff() {
  local local_pattern="$1"
  local master_branch local_branch

  if [[ -z "$local_pattern" ]]; then
    echo "Usage: gff <local_branch_pattern>"
    return 1
  fi

  master_branch=$(git branch --show-current)
  if [[ -z "$master_branch" ]]; then
    echo "Current directory is not on a branch"
    return 1
  fi

  gcd "$local_pattern" || return 1
  local_branch=$(git branch --show-current)
  if [[ -z "$local_branch" ]]; then
    echo "Cannot resolve local branch from pattern: $local_pattern"
    return 1
  fi

  git rebase "$master_branch" || return 1
  gcd "$master_branch" || return 1
  git merge --ff-only "$local_branch"
}

if [[ -x $(command -v nvim) ]];then
  alias v='nvim'
  function ngc() {
    if [[ $# -gt 0 ]];then
      COMMIT_ID=$1;
      nvim -c 'DiffviewOpen '"$COMMIT_ID"'^!' 
    fi
  }
  function ngd() {
    if [[ $# -gt 0 ]];then
      REVISION=$1;
      nvim -c 'DiffviewOpen '"$REVISION"
    fi
  }
