# yazi alias
if [[ -x $(command -v yazi) ]];then
  function y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
    yazi "$@" --cwd-file="$tmp"
    IFS= read -r -d '' cwd < "$tmp"
    [ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
    rm -f -- "$tmp"
  }
fi

# lf alias
if [[ -x $(command -v lf) ]];then
  function lfc () {
    cd "$(command lf -print-last-dir "$@")"
  }
fi
